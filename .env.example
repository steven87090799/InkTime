TZ=Asia/Taipei
INKTIME_PORT=8765
INKTIME_DATA_PATH=./data
INKTIME_PHOTO_PATH=./simulation_photos
INKTIME_COOKIE_SECURE=0
INKTIME_LOG_FORMAT=json
INKTIME_LOG_LEVEL=INFO
INKTIME_ACCESS_LOG=0
INKTIME_LOG_MAX_SIZE=5m
INKTIME_LOG_MAX_FILES=3
INKTIME_IMAGE_TAG=local

# Intel N100 低資源預設；這些是容器啟動邊界，日常工作並行與輪詢請在 Web 設定頁調整。
INKTIME_WEB_CPUS=0.75
INKTIME_WEB_MEMORY=384m
INKTIME_WEB_PIDS=128
INKTIME_WORKER_CPUS=2.0
INKTIME_WORKER_MEMORY=1g
INKTIME_WORKER_PIDS=192
INKTIME_SCHEDULER_CPUS=0.25
INKTIME_SCHEDULER_MEMORY=192m
INKTIME_SCHEDULER_PIDS=64
INKTIME_WEB_WORKERS=1
INKTIME_WEB_THREADS=2
INKTIME_GUNICORN_LOG_LEVEL=warning
